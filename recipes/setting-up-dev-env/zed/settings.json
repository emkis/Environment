// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "centered_layout": {
    "left_padding": 0.2
  },
  "diagnostics": {
    "inline": {
      "padding": 4
    }
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1"
    },
    "dock": "left",
    "button": true,
    "model_parameters": []
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tabs": {
    "show_diagnostics": "off",
    "file_icons": false,
    "git_status": false
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show": true
  },
  "title_bar": {
    "show_onboarding_banner": true,
    "show_menus": false,
    "show_sign_in": true,
    "show_user_picture": false,
    "show_branch_name": true,
    "show_branch_icon": false
  },
  "icon_theme": "Zed (Default)",
  "base_keymap": "VSCode",
  "vim_mode": false,
  "terminal": {
    "font_size": 14.0,
    "line_height": {
      "custom": 1.5
    }
  },
  "project_panel": {
    "indent_guides": {
      "show": "always"
    },
    "git_status": true,
    "folder_icons": true,
    "file_icons": true,
    "entry_spacing": "comfortable",
    "hide_hidden": true,
    "hide_root": true,
    "hide_gitignore": false,
    "default_width": 240.0,
    "dock": "right",
    "button": true,
    "auto_fold_dirs": false
  },
  "hidden_files": [
    "**/.cache",
    "**/.expo",
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/node_modules"
  ],
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": false
  },
  "status_bar": {
    "experimental.show": false
  },
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "minimap": {
    "show": "never"
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": true
    }
  },
  "current_line_highlight": "gutter",
  "confirm_quit": true,
  "buffer_font_family": "Fira Code",
  "formatter": "language_server",
  "file_types": {
    "jsonc": ["*.json"]
  },
  "colorize_brackets": true,
  "wrap_guides": [80, 100],
  "tab_size": 2,
  "ui_font_size": 16,
  "buffer_font_size": 17.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Dark",
    "dark": "Ayu Dark"
  }
}
